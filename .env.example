# Токен бота от @BotFather
BOT_TOKEN=

# Числовой ID администратора (@Olga_1Pervaya), куда слать заявки.
# Как узнать: запусти бота, напиши ему /id — он пришлёт твой ID. Вставь сюда.
ADMIN_ID=

# Прокси для обхода блокировки Telegram (если нет системного VPN).
# Оставь пустым, если используешь VPN на всём компьютере.
# Пример: PROXY_URL=socks5://1.2.3.4:1080  или  http://1.2.3.4:8080
PROXY_URL=

# --- Webhook (только для деплоя на Render) ---
# Локально оставь ПУСТЫМ — бот сам запустится через polling.
# На Render задавать НЕ нужно: адрес берётся автоматически из RENDER_EXTERNAL_URL.
# Заполняй вручную только если хостинг не отдаёт RENDER_EXTERNAL_URL.
WEBHOOK_URL=
